{
  "id": null,
  "uid": "minicloud-system-health",
  "title": "MiniCloud System Health (Fixed Units)",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",

  "panels": [
    {
      "type": "timeseries",
      "title": "CPU Usage (%)",
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      },
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(node_cpu_seconds_total{mode!=\"idle\"}[1m])) * 100",
          "refId": "A"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Memory Available",
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "node_memory_MemAvailable_bytes",
          "refId": "A"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Memory Used (%)",
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      },
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "refId": "A"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Network Receive (B/s)",
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      },
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(node_network_receive_bytes_total[1m]))",
          "refId": "A"
        }
      ]
    },

    {
      "type": "timeseries",
      "title": "Network Transmit (B/s)",
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      },
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(node_network_transmit_bytes_total[1m]))",
          "refId": "A"
        }
      ]
    }
  ]
}